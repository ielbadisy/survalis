X <- array(0, dim = c(n_samples, 1, 28, 28))
Y <- vector("integer", n_samples)
for (i in 1:n_samples) {
sample <- train_ds[i]
img_tensor <- sample[[1]]$to(dtype = torch_float())$div(255)  # normalize manually
X[i,,,] <- as.array(img_tensor)
Y[i] <- as.integer(sample[[2]])
}
Y <- factor(Y - 1, levels = 0:9)
# Step 4: Access CNN components (internal if needed)
create_architecture <- cito:::create_architecture
conv <- cito:::conv
maxPool <- cito:::maxPool
linear <- cito:::linear
