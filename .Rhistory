library(torchvision)
# Step 2: Install torch if needed
if (!torch::torch_is_installed()) {
torch::install_torch()
}
# Load 1000 MNIST images from torchvision with correct transform
train_ds <- mnist_dataset(
root = tempdir(),
download = TRUE,
train = TRUE,
transform = transform_to_tensor
)
# Extract the first 1000 samples
n_samples <- 1000
X <- array(0, dim = c(n_samples, 1, 28, 28))
Y <- vector("integer", n_samples)
for (i in 1:n_samples) {
sample <- train_ds[i]
img_tensor <- sample[[1]]$to(dtype = torch_float())$div(255)  # normalize manually
X[i,,,] <- as.array(img_tensor)
Y[i] <- as.integer(sample[[2]])
}
Y <- factor(Y)
# Step 4: Access CNN components (internal if needed)
create_architecture <- cito:::create_architecture
conv <- cito:::conv
maxPool <- cito:::maxPool
linear <- cito:::linear
cnn <- cito:::cnn
# Step 5: Define CNN architecture for MNIST
arch <- create_architecture(
conv(n_kernels = 8, kernel_size = 3),
maxPool(kernel_size = 2),
conv(n_kernels = 16, kernel_size = 3),
maxPool(kernel_size = 2),
linear(n_neurons = 64),
linear(n_neurons = 10)  # 10 output nodes for 10 classes
)
# Step 6: Train the CNN
