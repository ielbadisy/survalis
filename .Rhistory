}
basehaz <- estimate_baseline_cumhaz(object$time, object$status, object$eta, times)
survmat <- outer(eta_new, basehaz, function(e, h) exp(-h * exp(e)))
colnames(survmat) <- paste0("t=", times)
rownames(survmat) <- paste0("ID_", seq_len(nrow(newdata)))
as.data.frame(survmat)
}
mod_cb <- fit_coxtreeboost(
