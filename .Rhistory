X = X,
Y = Y,
architecture = arch,
loss = "softmax",       # Multi-class classification
optimizer = "adam",
lr = 0.01,
epochs = 10,
batchsize = 32,
validation = 0.2,
device = "cpu",         # or "cuda" if you have a GPU
