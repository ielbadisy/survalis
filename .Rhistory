# True survival outcome
truth <- with(test_data, survival::Surv(get(all.vars(formula[[2]])[1]), get(all.vars(formula[[2]])[2])))
# Compute score
scores[i] <- metric(truth, as.matrix(pred), times)
}
mean_score <- mean(scores)
results <- rbind(results, data.frame(rule = rule, score = mean_score))
if (mean_score < best_score) {
best_score <- mean_score
best_model <- fit_selectcox(formula, data, rule = rule, ...)
}
}
structure(list(
best_model = best_model,
results = results[order(results$score), ]
), class = "mlsurv_tuning")
}
fit_selectcox <- function(formula, data, rule = "aic", ...) {
stopifnot(requireNamespace("pec", quietly = TRUE))
model <- pec::selectCox(formula = formula, data = data, rule = rule, ...)
time_status <- all.vars(formula[[2]])
time_var <- time_status[1]
status_var <- time_status[2]
structure(list(
model = model,
learner = "selectcox",
formula = formula,
data = data,
time = time_var,
status = status_var
), class = "mlsurv_model", engine = "selectcox")
}
predict_selectcox <- function(object, newdata, times) {
stopifnot(object$learner == "selectcox")
stopifnot(requireNamespace("pec", quietly = TRUE))
survmat <- pec::predictSurvProb(object$model, newdata = newdata, times = times)
if (is.vector(survmat)) {
survmat <- matrix(survmat, nrow = 1)
}
colnames(survmat) <- paste0("t=", times)
rownames(survmat) <- paste0("ID_", seq_len(nrow(newdata)))
as.data.frame(survmat)
}
library(survival)
data(GBSG2)
mod_selectcox <- fit_selectcox(Surv(time, cens) ~ horTh + age + menostat + tsize +
tgrade + pnodes + progrec + estrec, data = GBSG2)
preds <- predict_selectcox(mod_selectcox, newdata = GBSG2[1:5, ], times = c(100, 200, 300))
print(round(preds, 3))
#' Tune SelectCox via Rule Criterion
#'
#' Tunes the SelectCox model by trying multiple selection rules.
#'
#' @param formula A survival formula.
#' @param data A data.frame with survival data.
#' @param rules A character vector of rules to try (default = c("aic", "bic", "p")).
#' @param times Time points at which to evaluate performance.
#' @param metric Evaluation metric function (e.g., integrated Brier score).
#' @param predict_fun Prediction function (default = predict_selectcox).
#' @param cv Number of cross-validation folds (default = 5).
#' @param seed Random seed for reproducibility.
#' @param ... Additional arguments passed to fit_selectcox().
#'
#' @return A list with best model and a tuning results data.frame.
#' @export
tune_selectcox <- function(formula, data,
rules = c("aic", "bic", "p"),
times,
metric,
predict_fun = predict_selectcox,
cv = 5,
seed = 123,
...) {
set.seed(seed)
stopifnot(length(times) > 0)
folds <- rsample::vfold_cv(data, v = cv, strata = all.vars(formula[[2]])[2])
results <- data.frame(rule = character(), score = numeric())
best_model <- NULL
best_score <- Inf
for (rule in rules) {
scores <- numeric(cv)
for (i in seq_along(folds$splits)) {
split <- folds$splits[[i]]
train_data <- rsample::analysis(split)
test_data  <- rsample::assessment(split)
mod <- fit_selectcox(formula, train_data, rule = rule, ...)
pred <- predict_fun(mod, test_data, times = times)
# True survival outcome
truth <- with(test_data, survival::Surv(get(all.vars(formula[[2]])[1]), get(all.vars(formula[[2]])[2])))
# Compute score
scores[i] <- metric(truth, as.matrix(pred), times)
}
mean_score <- mean(scores)
results <- rbind(results, data.frame(rule = rule, score = mean_score))
if (mean_score < best_score) {
best_score <- mean_score
best_model <- fit_selectcox(formula, data, rule = rule, ...)
}
}
structure(list(
best_model = best_model,
results = results[order(results$score), ]
), class = "mlsurv_tuning")
}
library(survival)
data(GBSG2)
tuned <- tune_selectcox(Surv(time, cens) ~ horTh + age + menostat + tsize + tgrade +
pnodes + progrec + estrec,
data = GBSG2,
rules = c("aic", "bic", "p"),
times = c(100, 300, 500),
metric = "ibs",
cv = 3)
