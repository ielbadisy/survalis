#=========================
# Feature Importance for Survival (Permutation-based)
#=========================
feature_importance_surv <- function(model, predict_function, newdata, times,
time_target, n_repetitions = 5,
loss_function = function(actual, pred) mean((actual - pred)^2)) {
# Exclude "time", "status", "event" columns
exclude_cols <- c("time", "status", "event")
covariates <- setdiff(names(newdata), exclude_cols)
# Predict once to get the base error
pred_base <- predict_function(model, newdata, times = time_target)[, 1]
true_status <- as.integer(newdata$time > time_target)  # Alive = 1 if time > t, Dead = 0 otherwise
original_loss <- loss_function(true_status, pred_base)
feature_results <- lapply(covariates, function(feature) {
permuted_losses <- numeric(n_repetitions)
for (i in 1:n_repetitions) {
newdata_perm <- newdata
newdata_perm[[feature]] <- sample(newdata_perm[[feature]])
pred_perm <- predict_function(model, newdata = newdata_perm, times = time_target)[, 1]
permuted_losses[i] <- loss_function(true_status, pred_perm)
}
importance <- median(permuted_losses - original_loss)
list(
feature = feature,
importance = importance,
importance_05 = quantile(permuted_losses - original_loss, 0.05),
importance_95 = quantile(permuted_losses - original_loss, 0.95)
)
})
importance_df <- do.call(rbind, lapply(feature_results, as.data.frame))
importance_df[order(-importance_df$importance), ]
}
#=========================
# Plot function
#=========================
plot_feature_importance_surv <- function(importance_df) {
library(ggplot2)
ggplot(importance_df, aes(x = reorder(feature, importance), y = importance)) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = importance_05, ymax = importance_95), width = 0.3) +
coord_flip() +
xlab("") +
ylab("Feature Importance (Δ Brier Score)") +
ggtitle("Permutation-based Feature Importance for Survival") +
theme_minimal()
}
# Use your survival model and predict function
dyn_imp <- feature_importance_surv(
model = mod_ranger,
predict_function = predict_ranger,
newdata = veteran,
times = times,
time_target = 200,          # time at which we assess
n_repetitions = 10
)
# View the result
print(dyn_imp)
# Plot the result
plot_feature_importance_surv(dyn_imp)
#*** other metric
#=========================
# Feature Importance for Survival (Integrated Error)
#=========================
feature_importance_surv <- function(model, predict_function, newdata, times,
loss_type = c("ISE", "IAE"),
n_repetitions = 5) {
loss_type <- match.arg(loss_type)
# Exclude "time", "status", "event"
exclude_cols <- c("time", "status", "event")
covariates <- setdiff(names(newdata), exclude_cols)
# True survival status matrix: alive = 1 if time > t
true_status <- outer(newdata$time, times, ">") * 1  # matrix (n x times)
# Predict once for base prediction
pred_base <- predict_function(model, newdata, times = times)  # matrix (n x times)
if (loss_type == "ISE") {
original_loss <- mean((true_status - pred_base)^2)
} else {
original_loss <- mean(abs(true_status - pred_base))
}
feature_results <- lapply(covariates, function(feature) {
permuted_losses <- numeric(n_repetitions)
for (i in 1:n_repetitions) {
newdata_perm <- newdata
newdata_perm[[feature]] <- sample(newdata_perm[[feature]])
pred_perm <- predict_function(model, newdata_perm, times = times)
if (loss_type == "ISE") {
loss_val <- mean((true_status - pred_perm)^2)
} else {
loss_val <- mean(abs(true_status - pred_perm))
}
permuted_losses[i] <- loss_val
}
importance <- median(permuted_losses - original_loss)
list(
feature = feature,
importance = importance,
importance_05 = quantile(permuted_losses - original_loss, 0.05),
importance_95 = quantile(permuted_losses - original_loss, 0.95)
)
})
importance_df <- do.call(rbind, lapply(feature_results, as.data.frame))
importance_df[order(-importance_df$importance), ]
}
#=========================
# Plot function
#=========================
plot_feature_importance_surv <- function(importance_df) {
library(ggplot2)
ggplot(importance_df, aes(x = reorder(feature, importance), y = importance)) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = importance_05, ymax = importance_95), width = 0.3) +
coord_flip() +
xlab("") +
ylab("Feature Importance (Δ Integrated Error)") +
ggtitle("Permutation-based Feature Importance for Survival Models") +
theme_minimal()
}
# Example with your fit and predict functions:
dyn_imp_ise <- feature_importance_surv(
model = mod_ranger,
predict_function = predict_ranger,
newdata = veteran,
times = times,
loss_type = "ISE",        # Integrated Square Error
n_repetitions = 10
)
