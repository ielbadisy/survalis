architecture = arch,
loss = "softmax",
optimizer = "adam",
lr = 0.001,           # Lower learning rate
epochs = 30,          # Longer training
burnin = 0,           # Don't auto-cancel
validation = 0,       # Turn off validation for now
device = "cpu",
plot = TRUE,
verbose = TRUE
)
# Step 7: Evaluate the model
preds <- predict(model, type = "class")
table(True = Y, Predicted = preds)
# Step 1: Install and load required packages
if (!requireNamespace("cito", quietly = TRUE)) install.packages("cito")
if (!requireNamespace("torch", quietly = TRUE)) install.packages("torch")
if (!requireNamespace("torchvision", quietly = TRUE)) install.packages("torchvision")
library(cito)
library(torch)
library(torchvision)
# Step 2: Install torch if needed
if (!torch::torch_is_installed()) {
torch::install_torch()
}
# Load 1000 MNIST images from torchvision with correct transform
train_ds <- mnist_dataset(
root = tempdir(),
download = TRUE,
train = TRUE,
transform = transform_to_tensor
)
# Extract the first 1000 samples
n_samples <- 1000
X <- array(0, dim = c(n_samples, 1, 28, 28))
Y <- vector("integer", n_samples)
for (i in 1:n_samples) {
sample <- train_ds[i]
img_tensor <- sample[[1]]$to(dtype = torch_float())$div(255)  # normalize manually
X[i,,,] <- as.array(img_tensor)
Y[i] <- as.integer(sample[[2]])
}
Y <- factor(Y - 1, levels = 0:9)
# Step 4: Access CNN components (internal if needed)
create_architecture <- cito:::create_architecture
conv <- cito:::conv
maxPool <- cito:::maxPool
linear <- cito:::linear
cnn <- cito:::cnn
# Step 5: Define CNN architecture for MNIST
arch <- cito:::create_architecture(
cito:::conv(n_kernels = 16, kernel_size = 3, activation = "relu", normalization = TRUE),
cito:::maxPool(kernel_size = 2),
cito:::conv(n_kernels = 32, kernel_size = 3, activation = "relu", normalization = TRUE),
cito:::maxPool(kernel_size = 2),
cito:::linear(n_neurons = 64, activation = "relu", dropout = 0.2)
#cito:::linear(n_neurons = 10)  # 10 digits
)
# Step 6: Train the CNN
model <- cito:::cnn(
X = X,
Y = factor(Y, levels = 0:9),
architecture = arch,
loss = "softmax",
optimizer = "adam",
lr = 0.001,           # Lower learning rate
epochs = 30,          # Longer training
burnin = 0,           # Don't auto-cancel
validation = 0,       # Turn off validation for now
device = "cpu",
plot = TRUE,
verbose = TRUE
)
# Step 7: Evaluate the model
preds <- predict(model, type = "class")
table(True = Y, Predicted = preds)
# Step 8: Plot architecture
plot(model)
