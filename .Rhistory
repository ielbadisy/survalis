risk_scores <- eta
cindex <- survival::concordance(survival::Surv(time, status) ~ risk_scores)$concordance
message(sprintf("Iteration %d - C-index: %.4f", m, cindex))
if (cindex > best_cindex + tol) {
best_cindex <- cindex
no_improve_rounds <- 0
} else {
no_improve_rounds <- no_improve_rounds + 1
if (no_improve_rounds >= early_stopping_rounds) {
message("Early stopping at iteration ", m)
break
}
}
}
}
structure(list(
model = models,
learner = "coxtreeboost",
formula = formula,
data = data,
eta = eta,
time = time,
status = status,
shrinkage = shrinkage
), class = "mlsurv_model", engine = "coxtreeboost")
}
predict_coxtreeboost <- function(object, newdata, times = NULL) {
stopifnot(object$learner == "coxtreeboost")
stopifnot(requireNamespace("rpart", quietly = TRUE))
newX <- model.matrix(object$formula, newdata)[, -1, drop = FALSE]
eta_new <- rep(0, nrow(newX))
for (i in seq_along(object$model)) {
eta_new <- eta_new + (object$shrinkage / sqrt(i)) * predict(object$model[[i]], newdata = as.data.frame(newX))
}
if (is.null(times)) return(eta_new)
estimate_baseline_cumhaz <- function(time, status, eta, eval_times) {
df <- data.frame(time = time, status = status, eta = eta)
df <- df[order(df$time), ]
unique_times <- sort(unique(df$time[df$status == 1]))
risk_scores <- exp(df$eta)
cumhaz <- numeric(length(unique_times))
for (j in seq_along(unique_times)) {
t_j <- unique_times[j]
at_risk <- df$time >= t_j
d_j <- sum(df$time == t_j & df$status == 1)
r_j <- sum(risk_scores[at_risk])
cumhaz[j] <- if (r_j > 0) d_j / r_j else 0
}
cumhaz <- cumsum(cumhaz)
names(cumhaz) <- unique_times
stepfun(unique_times, c(0, cumhaz), right = TRUE)(eval_times)
}
basehaz <- estimate_baseline_cumhaz(object$time, object$status, object$eta, times)
survmat <- outer(eta_new, basehaz, function(e, h) exp(-h * exp(e)))
colnames(survmat) <- paste0("t=", times)
rownames(survmat) <- paste0("ID_", seq_len(nrow(newdata)))
as.data.frame(survmat)
}
mod_cb <- fit_coxtreeboost(
Surv(time, status) ~ X1 + X2,
data = data_sim,
n_iter = 1000,
shrinkage = 0.05,
maxdepth = 3,
minsplit = 5,
verbose = TRUE
)
# Enhanced version of fit_coxtreeboost with performance improvements
fit_coxtreeboost <- function(
formula, data,
n_iter = 900,
shrinkage = 0.01,
maxdepth = 3,
minsplit = 3,
subsample = 0.8,
verbose = FALSE,
early_stopping_rounds = 30,
tol = 1e-4
) {
stopifnot(requireNamespace("rpart", quietly = TRUE))
stopifnot(requireNamespace("survival", quietly = TRUE))
mf <- model.frame(formula, data)
y <- model.response(mf)
X <- model.matrix(formula, data)[, -1, drop = FALSE]
time <- y[, "time"]
status <- y[, "status"]
n <- nrow(X)
eta <- rep(0, n)
models <- list()
best_cindex <- -Inf
no_improve_rounds <- 0
for (m in seq_len(n_iter)) {
# Gradient computation (approximate negative partial likelihood gradient)
order_idx <- order(time, decreasing = TRUE)
risk_score <- exp(eta[order_idx])
cum_risk <- rev(cumsum(rev(risk_score))) + 1e-8  # Stabilize denominator
grad <- status[order_idx] - risk_score / cum_risk
grad <- grad[order(order_idx)]
# Subsample rows
sample_idx <- sample(seq_len(n), size = floor(subsample * n))
tree_data <- data.frame(X[sample_idx, , drop = FALSE], grad = grad[sample_idx])
tree <- rpart::rpart(
grad ~ ., data = tree_data,
control = rpart::rpart.control(cp = 0.001, maxdepth = maxdepth, minsplit = minsplit)
)
update <- predict(tree, newdata = as.data.frame(X))
eta <- eta + (shrinkage / sqrt(m)) * update
models[[m]] <- tree
# Optional early stopping based on C-index
if (verbose && m %% 10 == 0) {
risk_scores <- eta
cindex <- survival::concordance(survival::Surv(time, status) ~ risk_scores)$concordance
message(sprintf("Iteration %d - C-index: %.4f", m, cindex))
if (cindex > best_cindex + tol) {
best_cindex <- cindex
no_improve_rounds <- 0
} else {
no_improve_rounds <- no_improve_rounds + 1
if (no_improve_rounds >= early_stopping_rounds) {
message("Early stopping at iteration ", m)
break
}
}
}
}
structure(list(
model = models,
learner = "coxtreeboost",
formula = formula,
data = data,
eta = eta,
time = time,
status = status,
shrinkage = shrinkage
), class = "mlsurv_model", engine = "coxtreeboost")
}
predict_coxtreeboost <- function(object, newdata, times = NULL) {
stopifnot(object$learner == "coxtreeboost")
stopifnot(requireNamespace("rpart", quietly = TRUE))
newX <- model.matrix(object$formula, newdata)[, -1, drop = FALSE]
