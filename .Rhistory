arch <- cito:::create_architecture(
cito:::conv(n_kernels = 16, kernel_size = 3, activation = "relu", normalization = TRUE),
cito:::maxPool(kernel_size = 2),
cito:::conv(n_kernels = 32, kernel_size = 3, activation = "relu", normalization = TRUE),
