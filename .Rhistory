for (i in seq_along(object$model)) {
eta_new <- eta_new + (object$shrinkage / sqrt(i)) * predict(object$model[[i]], newdata = as.data.frame(newX))
}
if (is.null(times)) return(eta_new)
estimate_baseline_cumhaz <- function(time, status, eta, eval_times) {
df <- data.frame(time = time, status = status, eta = eta)
df <- df[order(df$time), ]
unique_times <- sort(unique(df$time[df$status == 1]))
risk_scores <- exp(df$eta)
cumhaz <- numeric(length(unique_times))
for (j in seq_along(unique_times)) {
t_j <- unique_times[j]
at_risk <- df$time >= t_j
d_j <- sum(df$time == t_j & df$status == 1)
r_j <- sum(risk_scores[at_risk])
cumhaz[j] <- if (r_j > 0) d_j / r_j else 0
}
cumhaz <- cumsum(cumhaz)
