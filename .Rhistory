compute_pdp <- function(model, predict_function, data, feature, times,
method = "pdp+ice", grid.size = 20) {
requireNamespace("data.table")
if (!feature %in% names(data)) stop("Feature not found in data.")
feature_range <- range(data[[feature]], na.rm = TRUE)
grid_values <- seq(feature_range[1], feature_range[2], length.out = grid.size)
n_obs <- nrow(data)
expanded_data <- data[rep(seq_len(n_obs), each = grid.size), , drop = FALSE]
expanded_data[[feature]] <- rep(grid_values, times = n_obs)
surv_preds <- predict_function(model, newdata = expanded_data, times = times)
if (is.null(dim(surv_preds))) surv_preds <- matrix(surv_preds, nrow = 1)
surv_preds_dt <- data.table::as.data.table(surv_preds)
colnames(surv_preds_dt) <- paste0("t=", times)
surv_preds_dt[[feature]] <- rep(grid_values, times = n_obs)
surv_preds_dt$.id <- rep(seq_len(n_obs), each = grid.size)
results_list <- list()
if (method %in% c("ice", "pdp+ice")) {
ice_long <- data.table::melt(
surv_preds_dt,
id.vars = c(".id", feature),
variable.name = "time",
value.name = "surv_prob"
)
ice_long$type <- "ice"
results_list$ice <- ice_long
}
if (method %in% c("pdp", "pdp+ice")) {
pdp_dt <- surv_preds_dt[, lapply(.SD, mean),
by = feature, .SDcols = paste0("t=", times)]
pdp_long <- data.table::melt(
pdp_dt,
id.vars = feature,
variable.name = "time",
value.name = "surv_prob"
)
pdp_long$type <- "pdp"
pdp_long$.id <- NA
results_list$pdp <- pdp_long
}
final_result <- data.table::rbindlist(results_list, use.names = TRUE, fill = TRUE)
final_result[, time := as.numeric(gsub("t=", "", time))]
pdp_integrated <- NULL
if ("pdp" %in% unique(final_result$type)) {
integrate_fun <- function(x, y) {
sum((head(y, -1) + tail(y, -1)) / 2 * diff(x))
}
pdp_integrated <- final_result[type == "pdp", .(
integrated_surv = integrate_fun(time, surv_prob)
), by = feature]
}
list(
results = final_result,
pdp_integrated = pdp_integrated
)
}
