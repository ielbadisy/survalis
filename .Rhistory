library(splines)
library(survival)
library(rpart)
prepare_tve_design <- function(formula, data, df_spline = 2) {
mf <- model.frame(formula, data)
X <- model.matrix(formula, data)[, -1, drop = FALSE]
y <- model.response(mf)
time <- y[, "time"]
status <- y[, "status"]
time_basis <- ns(time, df = df_spline)
colnames(time_basis) <- paste0("B", seq_len(ncol(time_basis)))
interactions <- do.call(cbind, lapply(seq_len(ncol(X)), function(j) {
xi <- X[, j]
out <- xi * time_basis
colnames(out) <- paste0(colnames(X)[j], "_", colnames(time_basis))
out
}))
design <- as.data.frame(interactions)
list(
design = design,
time = time,
status = status,
spline_basis = time_basis,
X = X,
y = y,
df_spline = df_spline
)
}
fit_tve_coxboost <- function(formula, data, df_spline = 4, n_iter = 100, shrinkage = 0.1, maxdepth = 1) {
design_data <- prepare_tve_design(formula, data, df_spline)
X <- design_data$design
time <- design_data$time
status <- design_data$status
n <- nrow(X)
eta <- rep(0, n)
models <- list()
for (m in seq_len(n_iter)) {
message("Iteration: ", m)
order_idx <- order(time, decreasing = TRUE)
risk_score <- exp(eta[order_idx])
cum_risk <- rev(cumsum(rev(risk_score))) + 1e-8
grad <- status[order_idx] - risk_score / cum_risk
grad <- grad[order(order_idx)]
tree_data <- cbind(X, grad = grad)
tree <- rpart(grad ~ ., data = tree_data, control = rpart.control(cp = 0, maxdepth = maxdepth))
update <- predict(tree, newdata = X)
eta <- eta + shrinkage * update
models[[m]] <- tree
}
structure(list(
models = models,
eta = eta,
formula = formula,
df_spline = df_spline,
design_data = design_data,
shrinkage = shrinkage
), class = "tve_coxboost")
}
predict_eta_tve_coxboost <- function(object, newdata) {
tv_data <- prepare_tve_design(object$formula, newdata, object$df_spline)
X_new <- tv_data$design
eta <- rep(0, nrow(X_new))
for (model in object$models) {
eta <- eta + object$shrinkage * predict(model, newdata = X_new)
}
eta
}
plot_beta_tve <- function(object, variable, times = NULL, lwd = 2, col = "blue") {
if (is.null(times)) {
times <- sort(unique(object$design_data$time))
}
spline_basis <- ns(times, df = object$df_spline)
colnames(spline_basis) <- paste0("B", seq_len(ncol(spline_basis)))
term_names <- paste0(variable, "_", colnames(spline_basis))
coefs <- setNames(numeric(length(term_names)), term_names)
for (tree in object$models) {
vars <- unique(tree$frame$var)
for (v in term_names) {
if (v %in% vars) {
coefs[v] <- coefs[v] + object$shrinkage
}
}
}
beta_t <- as.numeric(spline_basis %*% as.numeric(coefs))
plot(times, beta_t, type = "l", col = col, lwd = lwd,
xlab = "Time", ylab = bquote(beta[.(variable)](t)),
main = bquote("Estimated "~beta[.(variable)]~"(t)"))
grid()
}
tve_variable_importance <- function(object) {
all_vars <- unlist(lapply(object$models, function(tree) {
unique(tree$frame$var[tree$frame$var != "<leaf>"])
}))
base_vars <- gsub("_B[0-9]+", "", all_vars)
counts <- table(base_vars)
sort_df <- as.data.frame(sort(counts, decreasing = TRUE))
colnames(sort_df) <- c("Variable", "Importance")
sort_df
}
# 1. Simulate time-varying effect data
set.seed(123)
n <- 300
X1 <- runif(n)
X2 <- runif(n)
lp <- -3 * X1 - 2 * X2
time <- rexp(n, rate = exp(lp))
status <- rbinom(n, 1, 0.9)
data_sim <- data.frame(X1 = X1, X2 = X2, time = time, status = status)
# 2. Fit TVE CoxBoost model
mod_tve <- fit_tve_coxboost(
Surv(time, status) ~ X1 + X2,
data = data_sim,
df_spline = 4,
n_iter = 100,
shrinkage = 0.1,
maxdepth = 1
)
# 3. Predict log-risk scores
eta_pred <- predict_eta_tve_coxboost(mod_tve, newdata = data_sim)
# 4. Compute C-index
c_index <- concordance(Surv(data_sim$time, data_sim$status) ~ eta_pred)$concordance
cat("C-index (TVE CoxBoost):", round(c_index, 3), "\n")
# 5. Plot estimated time-varying coefficient for X1 and X2
plot_beta_tve(mod_tve, variable = "X1", col = "darkred")
plot_beta_tve(mod_tve, variable = "X2", col = "darkblue")
# 6. Variable importance ranking
print(tve_variable_importance(mod_tve))
fit_tvecoxboost <- function(formula, data,
df_spline = 4,
n_iter = 100,
shrinkage = 0.1,
maxdepth = 1) {
design_data <- prepare_tve_design(formula, data, df_spline)
X <- design_data$design
time <- design_data$time
status <- design_data$status
n <- nrow(X)
eta <- rep(0, n)
models <- list()
for (m in seq_len(n_iter)) {
# Compute pseudo-residuals
order_idx <- order(time, decreasing = TRUE)
risk_score <- exp(eta[order_idx])
cum_risk <- rev(cumsum(rev(risk_score)))
grad <- status[order_idx] - risk_score / cum_risk
grad <- grad[order(order_idx)]
tree_data <- cbind(X, grad = grad)
tree <- rpart::rpart(grad ~ ., data = tree_data,
control = rpart.control(cp = 0, maxdepth = maxdepth))
update <- predict(tree, newdata = X)
eta <- eta + shrinkage * update
models[[m]] <- tree
}
structure(list(
model = models,
learner = "tvecoxboost",
formula = formula,
data = data,
time = design_data$time,
status = design_data$status,
shrinkage = shrinkage,
df_spline = df_spline
), class = "mlsurv_model", engine = "tvecoxboost")
}
predict_tvecoxboost <- function(object, newdata, times = NULL) {
# Predict η
design_new <- prepare_tve_design(object$formula, newdata, df_spline = object$df_spline)$design
eta_new <- rep(0, nrow(design_new))
for (tree in object$model) {
eta_new <- eta_new + object$shrinkage * predict(tree, newdata = design_new)
}
if (is.null(times)) {
return(eta_new)
}
# Estimate baseline cumulative hazard from training data
basehaz <- estimate_baseline_cumhaz(
time = object$time,
status = object$status,
eta = sapply(seq_along(object$time), function(i) {
row <- prepare_tve_design(object$formula, object$data[i, , drop = FALSE], object$df_spline)$design
sum(sapply(seq_along(object$model), function(j) {
object$shrinkage * predict(object$model[[j]], newdata = row)
}))
}),
eval_times = times
)
# Compute survival probabilities
surv_probs <- outer(eta_new, basehaz, function(e, h) exp(-h * exp(e)))
colnames(surv_probs) <- paste0("t=", times)
rownames(surv_probs) <- paste0("ID_", seq_len(nrow(newdata)))
return(as.data.frame(surv_probs))
}
cv_results <- cv_survlearner(
formula = Surv(time, status) ~ karno + celltype + age +diagtime,
data = veteran,
fit_fun = fit_tvecoxboost,
pred_fun = predict_tvecoxboost,
times = c(100, 300, 500),
metrics = c("cindex"),
folds = 5
)
cv_summary(cv_results)
summary(cv_results)
cv_results
