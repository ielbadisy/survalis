batchsize = 16,
validation = 0.2,
device = "cpu",
plot = TRUE,
verbose = TRUE
)
# 7. Evaluate predictions
preds <- predict(model, type = "class")
print(table(True = Y, Predicted = preds))
# 8. Plot CNN architecture
plot(model)
# 1. Load required packages
if (!requireNamespace("cito", quietly = TRUE)) install.packages("cito")
if (!requireNamespace("torch", quietly = TRUE)) install.packages("torch")
library(cito)
library(torch)
# 2. Ensure torch is installed
if (!torch_is_installed()) {
install_torch()
}
# 3. Simulate synthetic 32x32 grayscale images
set.seed(123)
n_samples <- 100
image_size <- 32
channels <- 1
X <- array(runif(n_samples * channels * image_size * image_size),
dim = c(n_samples, channels, image_size, image_size))
# Binary labels: 50 zeros, 50 ones
Y <- factor(rep(c(0, 1), each = n_samples / 2))
# 4. Use internal CNN-building functions from cito
create_architecture <- cito:::create_architecture
conv <- cito:::conv
maxPool <- cito:::maxPool
linear <- cito:::linear
cnn <- cito:::cnn
# 5. Define CNN architecture
arch <- create_architecture(
conv(n_kernels = 8, kernel_size = 3),
maxPool(kernel_size = 2),
conv(n_kernels = 16, kernel_size = 3),
maxPool(kernel_size = 2),
linear(n_neurons = 32),
linear(n_neurons = 2)  # 2 output neurons for binary classification with softmax
)
# 6. Train CNN model
model <- cnn(
X = X,
Y = Y,
architecture = arch,
loss = "softmax",
optimizer = "adam",
lr = 0.01,
epochs = 10,
batchsize = 16,
validation = 0.2,
device = "cpu",
plot = TRUE,
verbose = TRUE
)
# 7. Evaluate predictions
preds <- predict(model, type = "class")
print(table(True = Y, Predicted = preds))
# 8. Plot CNN architecture
plot(model)
