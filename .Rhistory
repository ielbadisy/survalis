#' Compute survival-adapted R²(t)
#' @param model Fitted model object (must have same format as fit_*() outputs)
#' @param predict_function Function to obtain survival probabilities (e.g., predict_ranger)
#' @param newdata Validation data
#' @param times Vector of evaluation time points
#' @param time_var Name of time column (default: "time")
#' @param status_var Name of status/event column (default: "status")
#' @param reference Kaplan-Meier reference survival
#' @param loss_fn Function to compute error (default: squared loss)
#' @return Data frame with R²(t) values over time
compute_r2_surv <- function(model, predict_function, newdata, times,
time_var = "time", status_var = "status",
reference = NULL,
loss_fn = function(true, pred) (true - pred)^2) {
stopifnot(is.function(predict_function), is.data.frame(newdata))
# Step 1: predict survival probabilities
S_pred <- predict_function(model, newdata = newdata, times = times)  # matrix n x T
# Step 2: Compute true event status at time t: 1 if event before t, 0 otherwise
status_matrix <- outer(newdata[[time_var]], times, FUN = "<=") & newdata[[status_var]] == 1
true_status <- 1 * status_matrix  # binary event indicator matrix (n x T)
# Step 3: Compute Brier Score (MSE)
mse_model <- colMeans(loss_fn(true_status, S_pred), na.rm = TRUE)
# Step 4: Reference model: Kaplan-Meier survival on newdata
if (is.null(reference)) {
km_fit <- survfit(Surv(newdata[[time_var]], newdata[[status_var]]) ~ 1)
S_km <- summary(km_fit, times = times)$surv
S_km_mat <- matrix(rep(S_km, each = nrow(newdata)), nrow = nrow(newdata))
mse_ref <- colMeans(loss_fn(true_status, S_km_mat), na.rm = TRUE)
} else {
mse_ref <- reference  # allow external reference MSE
}
# Step 5: Compute R2(t)
R2_vals <- 1 - (mse_model / mse_ref)
R2_vals[mse_ref == 0] <- NA  # avoid division by zero
data.frame(time = times, R2 = R2_vals)
}
# Example
model <- fit_ranger(Surv(time, status) ~ x1 + x2, data = dat)
times <- seq(100, 500, length.out = 20)
#' Compute survival-adapted R²(t)
#' @param model Fitted model object (must have same format as fit_*() outputs)
#' @param predict_function Function to obtain survival probabilities (e.g., predict_ranger)
#' @param newdata Validation data
#' @param times Vector of evaluation time points
#' @param time_var Name of time column (default: "time")
#' @param status_var Name of status/event column (default: "status")
#' @param reference Kaplan-Meier reference survival
#' @param loss_fn Function to compute error (default: squared loss)
#' @return Data frame with R²(t) values over time
compute_r2_surv <- function(model, predict_function, newdata, times,
time_var = "time", status_var = "status",
reference = NULL,
loss_fn = function(true, pred) (true - pred)^2) {
stopifnot(is.function(predict_function), is.data.frame(newdata))
# Step 1: predict survival probabilities
S_pred <- predict_function(model, newdata = newdata, times = times)  # matrix n x T
# Step 2: Compute true event status at time t: 1 if event before t, 0 otherwise
status_matrix <- outer(newdata[[time_var]], times, FUN = "<=") & newdata[[status_var]] == 1
true_status <- 1 * status_matrix  # binary event indicator matrix (n x T)
# Step 3: Compute Brier Score (MSE)
mse_model <- colMeans(loss_fn(true_status, S_pred), na.rm = TRUE)
# Step 4: Reference model: Kaplan-Meier survival on newdata
if (is.null(reference)) {
km_fit <- survfit(Surv(newdata[[time_var]], newdata[[status_var]]) ~ 1)
S_km <- summary(km_fit, times = times)$surv
S_km_mat <- matrix(rep(S_km, each = nrow(newdata)), nrow = nrow(newdata))
mse_ref <- colMeans(loss_fn(true_status, S_km_mat), na.rm = TRUE)
} else {
mse_ref <- reference  # allow external reference MSE
}
# Step 5: Compute R2(t)
R2_vals <- 1 - (mse_model / mse_ref)
R2_vals[mse_ref == 0] <- NA  # avoid division by zero
data.frame(time = times, R2 = R2_vals)
}
